<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        .header-list li {
            list-style: none;
            padding: 5px 12px;
        }
        .header-list ul {
            display:flex;
        }
        .header-list {
            background-color: #81b58f;
            max-width: 800px;
            margin-left:300px;
        }
        img {
           max-width:200px;
           max-height:200px;
           border-radius:8px;
        }
        .main {
            padding: 10px 3px 0px 20px;
            margin-left:270px;
            background-color: antiquewhite;
            max-width: 860px;
        }
        @media screen and (max-width: 960px) {
            .main {
                padding-left:10px;
                margin:auto;
            }
            .header-list {
                margin:0 auto;
                max-width:300px;
            }
            .header-list li {
                padding:2px 10px;
                margin:auto;
            }
        }
    </style>
    <title><%= title %></title>
</head>
<body>
   <header>
        <nav>
            <div class="header-list">
                <ul>
                    <li><h2>テスてぃん</h2></li>
                    <li><h3><a href="/news">お知らせ一覧</a></h3></li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="main">
        <h2><%= date %></h2>
        <%- body %>
    </div>
</body>
</html>