<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        .header-list li {
            list-style: none;
            padding: 5px 12px;
        }
        .header-list ul {
            display:flex;
        }
        .header-list {
            background-color: #81b58f;
            max-width: 800px;
            margin-left:300px;
        }
        .main {
            padding-left:60px;
            margin:0 auto;
        }
        .post_card {
            background-color: #ccd674;
            height:150px;
            width:300px;
            padding:1px 0px 30px 20px;
        }
        .main li {
            list-style: none;
        }
        .main ul {
            margin-left:330px;
        }
        .main h1 {
            margin-left:400px;
        }
        @media screen and (max-width: 960px) {
            .main {
                padding-left:10px;
            }
            .post_card {
                width:200px;
                height:150px;
            }
            .main ul {
                margin:auto;
            }
            .main li {
                list-style:none;
            }
            .main h1 {
                margin:auto;
            }
            .header-list {
                margin:0 auto;
                max-width:300px;
            }
            .header-list li {
                padding:2px 10px;
                margin:auto;
            }
        }
    </style>
    <title>お知らせ一覧</title>
</head>
<body>
    <header>
        <nav>
            <div class="header-list">
                <ul>
                    <li><h2>テステス</h2></li>
                    <li><h3><a href="/news">お知らせ一覧</a></h3></li>
                </ul>
            </div>
        </nav>
    </header>
    <div class="main">
        <h1>お知らせ一覧</h1>
        <ul>
            <% posts.forEach(post => { %>
                <li>
                    <div class="post_card">
                        <h4><%= post.date %></h4>
                        <h2><a href="/news/<%= post.slug %>"><%= post.title %></a></h2>
                        <h3><%= post.headline %></h3>
                    </div>
                </li>
                <br>
            <% }) %>
        </ul>
    </div>
</body>
</html>